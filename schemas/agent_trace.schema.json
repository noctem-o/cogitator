{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cogitator Agent Trace",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["step", "role", "assistant_message", "tool_requests", "is_final"],
    "properties": {
      "step": { "type": "integer", "minimum": 0 },
      "role": { "type": "string" },
      "assistant_message": { "type": "string" },
      "tool_requests": {
        "type": "array",
        "items": { "type": "object" }
      },
      "is_final": { "type": "boolean" },
      "decision": { "type": ["object", "array", "string", "number", "boolean", "null"] }
    }
  }
}
