{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cogitator Witness Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "agent",
    "mode",
    "artifacts",
    "schema_versions",
    "bundle_hash"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "integer", "minimum": 0 },
    "agent": { "type": "string" },
    "mode": { "type": "string", "enum": ["live", "replay"] },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "blake3"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "blake3": { "type": "string" }
        }
      }
    },
    "schema_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_manifest",
        "agent_trace",
        "tool_transcript",
        "drift_report",
        "hash_chain"
      ],
      "properties": {
        "witness_manifest": { "type": "integer", "minimum": 1 },
        "agent_trace": { "type": "integer", "minimum": 1 },
        "tool_transcript": { "type": "integer", "minimum": 1 },
        "drift_report": { "type": "integer", "minimum": 1 },
        "hash_chain": { "type": "integer", "minimum": 1 }
      }
    },
    "bundle_hash": { "type": "string" },
    "replay_source": { "type": ["string", "null"] }
  }
}
